# ---------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ---------------------------------------------------------------------------
# Use the Supabase DIRECT connection (port 5432) so Prisma Migrate works.
# For a pooled runtime connection, append ?pgbouncer=true and use port 6543.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-region.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Supabase Auth & Storage
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---------------------------------------------------------------------------
# AI (Vercel AI SDK) — document extraction
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ---------------------------------------------------------------------------
# Checkmyguest (CMG) — legacy occupancy integration
# ---------------------------------------------------------------------------
CMG_API_BASE="https://api.checkmyguest.com/v2"
# Numeric host id. Leave empty to auto-detect after login.
CMG_HOST_ID=""
# Provide either a static token, or login email + password.
CMG_TOKEN=""
CMG_EMAIL=""
CMG_PASSWORD=""

